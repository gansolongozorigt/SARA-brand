# WooCommerce read-proxy credentials (server-side only — NEVER prefix with VITE_).
# Copy this file to .env.local (gitignored) for local `vercel dev` testing.
# In Vercel these three are set for Production and Preview (marked Sensitive);
# Development is intentionally unset there, so local runs read from .env.local.

# WooCommerce site base URL (the function appends /wp-json/wc/v3).
WOO_API_URL=https://api.sarabrand.mn

# REST API key "SARA Frontend" (Read). Query-string auth is used (this host
# strips the Authorization header, so Basic Auth 401s).
WOO_CONSUMER_KEY=ck_your_consumer_key_here
WOO_CONSUMER_SECRET=cs_your_consumer_secret_here
